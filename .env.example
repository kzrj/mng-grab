# Скопируйте в .env и при необходимости измените значения.
# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mng_grab

# Backend
ENV=development

# Expo: укажите внешний IP или hostname сервера, чтобы приложение с телефона подключалось по QR
EXPO_PACKAGER_HOSTNAME=localhost
# URL бэкенда для приложения (без /api/v1). На сервере: http://34.172.114.64:8000 или https://домен
EXPO_PUBLIC_API_BASE=http://192.168.0.14:8000
